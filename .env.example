# ─── Local development ───────────────────────────────────────────────────────
PORT=3000
# Leave DATABASE_URL unset locally — the app uses SQLite automatically.
# Do NOT copy postgres.railway.internal URLs here; that hostname only works on Railway.

FRONTEND_URL=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000,http://127.0.0.1:3000

# Local M-Pesa testing requires a public HTTPS tunnel (ngrok / localtunnel)
BACKEND_URL=https://your-ngrok-url.ngrok.io

# ─── Railway production (set in Railway dashboard → Variables) ───────────────
# NODE_ENV=production
# DATABASE_URL          ← auto-injected when you add Postgres and link it to this service
# RAILWAY_PUBLIC_DOMAIN ← auto-injected by Railway (used for M-Pesa callbacks if BACKEND_URL is unset)
# BACKEND_URL=https://your-app.up.railway.app   ← optional override; auto-detected if omitted
# FRONTEND_URL=https://your-app.up.railway.app  ← only needed if frontend is on a different domain

# ─── M-Pesa Daraja API ───────────────────────────────────────────────────────
# Copy ALL four values from the SAME app page:
# https://developer.safaricom.co.ke → My Apps → [your app] → Lipa Na M-Pesa Online → Test credentials
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_online_passkey_here
MPESA_ENVIRONMENT=sandbox

# ─── Admin API authentication ────────────────────────────────────────────────
ADMIN_TOKEN=enjoyment-admin-token
